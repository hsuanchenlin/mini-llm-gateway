# Mini LLM Gateway — environment variables.
#
# Copy this file to `.env` and edit the values you need.
# `.env` is gitignored. The gateway itself does NOT auto-load .env;
# either source it (`set -a; . ./.env; set +a`) or use the run-*.sh scripts.

# --- Gateway server ---

# TCP port the gateway listens on.
GATEWAY_PORT=8090

# Per-request context timeout (applies to upstream calls and the gateway response).
# 120s accommodates cold-start LLM loads; bump higher if you use larger models.
GATEWAY_REQUEST_TIMEOUT_SECONDS=120

# Where the SQLite request log lives (will be created if missing).
GATEWAY_DB_PATH=mini-llm-gateway.db

# Bearer-token auth. When set, /v1/chat/completions and /admin/* require
# `Authorization: Bearer <token>`. /health and the web UI remain open.
# Leave empty to disable auth.
GATEWAY_AUTH_TOKEN=

# --- Provider routing ---

# Comma-separated providers to enable. Choose from: fake, ollama, openai.
GATEWAY_PROVIDERS=fake

# Provider used when a request omits "provider". Must be in GATEWAY_PROVIDERS.
GATEWAY_DEFAULT_PROVIDER=fake

# Model used when a request omits "model".
GATEWAY_DEFAULT_MODEL=fake-1

# --- Ollama (only required when GATEWAY_PROVIDERS includes "ollama") ---

OLLAMA_BASE_URL=http://localhost:11434

# --- OpenAI-compatible upstream (only required when GATEWAY_PROVIDERS includes "openai") ---

# Use https://api.openai.com for OpenAI itself, or any compatible base URL
# (Groq: https://api.groq.com/openai, Together, Fireworks, local llama.cpp, ...).
OPENAI_BASE_URL=https://api.openai.com

# Required if openai is enabled. For local servers without auth, set to any
# non-empty string (the upstream will ignore the Authorization header).
OPENAI_API_KEY=

# --- RAG (optional) ---
# Leave GATEWAY_EMBEDDER unset to disable RAG entirely. When set, the gateway
# enables document ingestion + retrieval: chat requests with "rag":true will
# embed the user's last message and prepend the top-K matching chunks as a
# system message before calling the chat provider.

# Embedder: "" (disabled), "fake", "ollama", or "openai".
GATEWAY_EMBEDDER=

# Embedding models per backend.
OLLAMA_EMBED_MODEL=nomic-embed-text
OPENAI_EMBED_MODEL=text-embedding-3-small

# Vector store: "qdrant" (production) or "inmemory" (no extra service; data lost on restart).
RAG_VECTOR_STORE=inmemory
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=chunks

# Retrieval + chunking knobs.
RAG_TOP_K=4
RAG_CHUNK_SIZE=1000
RAG_OVERLAP=100
